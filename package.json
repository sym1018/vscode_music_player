{
  "name": "vscode-music-player-sym1018",
  "displayName": "vscode music player sym1018",
  "description": "Local music player for VSCode with LRC lyrics display",
  "version": "0.1.21",
  "publisher": "sym1018",
  "repository": {
    "type": "git",
    "url": "https://github.com/sym1018/vscode_music_player"
  },
  "icon": "media/icon.png",
  "license": "MIT",
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "music",
    "player",
    "audio",
    "lyrics",
    "lrc",
    "mp3"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "musicPlayer.play",
        "title": "Play/Pause",
        "category": "Music Player",
        "icon": "$(play)"
      },
      {
        "command": "musicPlayer.next",
        "title": "Next Track",
        "category": "Music Player",
        "icon": "$(chevron-right)"
      },
      {
        "command": "musicPlayer.previous",
        "title": "Previous Track",
        "category": "Music Player",
        "icon": "$(chevron-left)"
      },
      {
        "command": "musicPlayer.volumeUp",
        "title": "Volume Up",
        "category": "Music Player"
      },
      {
        "command": "musicPlayer.volumeDown",
        "title": "Volume Down",
        "category": "Music Player"
      },
      {
        "command": "musicPlayer.toggleLyric",
        "title": "Toggle Lyrics",
        "category": "Music Player"
      },
      {
        "command": "musicPlayer.switchMode",
        "title": "Switch Play Mode",
        "category": "Music Player"
      },
      {
        "command": "musicPlayer.selectFolder",
        "title": "Select Music Folder",
        "category": "Music Player",
        "icon": "$(folder-opened)"
      },
      {
        "command": "musicPlayer.seek",
        "title": "Seek",
        "category": "Music Player"
      },
      {
        "command": "musicPlayer.playSong",
        "title": "Play Song",
        "category": "Music Player"
      },
      {
        "command": "musicPlayer.openMedia",
        "title": "Open Media File",
        "category": "Music Player"
      },
      {
        "command": "musicPlayer.seekForward",
        "title": "Seek Forward",
        "category": "Music Player"
      },
      {
        "command": "musicPlayer.seekBackward",
        "title": "Seek Backward",
        "category": "Music Player"
      },
      {
        "command": "musicPlayer.speedUp",
        "title": "Speed Up (Fast Forward)",
        "category": "Music Player"
      },
      {
        "command": "musicPlayer.speedNormal",
        "title": "Normal Speed",
        "category": "Music Player"
      },
      {
        "command": "musicPlayer.toggleFastForward",
        "title": "Toggle Fast Forward",
        "category": "Music Player"
      }
    ],
    "configuration": {
      "title": "Music Player",
      "properties": {
        "musicPlayer.musicFolder": {
          "type": "string",
          "default": "",
          "description": "Path to music folder"
        },
        "musicPlayer.volume": {
          "type": "number",
          "default": 50,
          "minimum": 0,
          "maximum": 100,
          "description": "Default volume (0-100)"
        },
        "musicPlayer.playMode": {
          "type": "string",
          "default": "sequence",
          "enum": [
            "sequence",
            "loop",
            "single",
            "random"
          ],
          "enumDescriptions": [
            "Sequential playback",
            "Loop all",
            "Single track loop",
            "Random"
          ],
          "description": "Play mode"
        },
        "musicPlayer.seekStep": {
          "type": "number",
          "default": 10,
          "minimum": 1,
          "maximum": 60,
          "description": "Seek forward/backward step in seconds (1-60)"
        },
        "musicPlayer.fastSpeed": {
          "type": "number",
          "default": 2,
          "minimum": 1.5,
          "maximum": 4,
          "description": "Fast playback speed for long-press (1.5-4x)"
        }
      }
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "musicPlayer",
          "title": "Music Player",
          "icon": "media/music.svg"
        }
      ]
    },
    "views": {
      "musicPlayer": [
        {
          "id": "musicPlayer-songList",
          "name": "Song List"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "musicPlayer.selectFolder",
          "when": "view == musicPlayer-songList",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "build": "node esbuild.js",
    "package": "npx @vscode/vsce package"
  },
  "devDependencies": {
    "@types/node": "^25.3.3",
    "@types/vscode": "~1.75.0",
    "esbuild": "^0.27.3",
    "typescript": "^5.9.3"
  }
}
